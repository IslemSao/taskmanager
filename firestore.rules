rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function authUid() {
      return request.auth.uid;
    }

    function authEmail() {
      return request.auth.token.email != null
        ? request.auth.token.email.lower()
        : "";
    }

    function isSelf(userId) {
      return isAuthenticated() && authUid() == userId;
    }

    function projectDoc(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId));
    }

    function projectExists(projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId));
    }

    function projectData(projectId) {
      return projectDoc(projectId).data;
    }

    function isProjectMemberFromData(data) {
      return isAuthenticated() && data != null && (
        data.ownerId == authUid() ||
        (data.members is list && authUid() in data.members) ||
        (data.memberIds is list && authUid() in data.memberIds)
      );
    }

    function isProjectMember(projectId) {
      return projectExists(projectId) && isProjectMemberFromData(projectData(projectId));
    }

    function isProjectOwner(projectId) {
      return isAuthenticated() &&
        projectExists(projectId) &&
        projectData(projectId).keys().hasAny(['ownerId']) &&
        projectData(projectId).ownerId == authUid();
    }

    function isInvitationRecipientFromData(data) {
      return isAuthenticated() && data != null && (
        data.inviteeId == authUid() ||
        (authEmail() != "" && data.inviteeEmail == authEmail())
      );
    }

    function isInvitationActorFromData(data) {
      return isAuthenticated() && data != null && (
        data.inviterId == authUid() ||
        isInvitationRecipientFromData(data)
      );
    }

    function canReadInvitation(data) {
      return isInvitationActorFromData(data) || (
        data != null &&
        data.keys().hasAny(['projectId']) &&
        data.projectId is string &&
        isProjectOwner(data.projectId)
      );
    }

    function isTaskActorFromData(data) {
      return isAuthenticated() && data != null && (
        data.userId == authUid() ||
        data.createdBy == authUid() ||
        data.assignedTo == authUid() ||
        (data.visibleToUserIds is list && authUid() in data.visibleToUserIds)
      );
    }

    function listChangesOnlySelf(oldList, newList) {
      return newList.hasOnly(oldList.concat([authUid()])) &&
        oldList.hasOnly(newList.concat([authUid()]));
    }

    function isSelfMembershipOnlyProjectUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['members', 'memberIds']) &&
        resource.data.members is list &&
        resource.data.memberIds is list &&
        request.resource.data.members is list &&
        request.resource.data.memberIds is list &&
        listChangesOnlySelf(resource.data.members, request.resource.data.members) &&
        listChangesOnlySelf(resource.data.memberIds, request.resource.data.memberIds);
    }

    function hasValidProjectMemberLists(data, ownerId) {
      return data.keys().hasAll(['members', 'memberIds']) &&
        data.members is list &&
        data.memberIds is list &&
        ownerId in data.members &&
        ownerId in data.memberIds;
    }

    function hasValidProjectWriteShape(data, ownerId) {
      return data.ownerId == ownerId &&
        hasValidProjectMemberLists(data, ownerId);
    }

    function isValidProjectMemberWrite(data, projectId, memberId, allowOwnerRole) {
      return data.projectId == projectId &&
        data.userId == memberId &&
        data.email is string &&
        data.displayName is string &&
        data.role is string &&
        (
          data.role == 'MEMBER' ||
          (allowOwnerRole && data.role == 'OWNER')
        );
    }

    function canManageLegacyMemberDoc(data) {
      return data != null &&
        data.keys().hasAny(['projectId']) &&
        data.projectId is string &&
        (
          isProjectOwner(data.projectId) ||
          (
            data.keys().hasAny(['userId']) &&
            data.userId == authUid()
          )
        );
    }

    function isValidLegacyMemberWrite(data) {
      return canManageLegacyMemberDoc(data) &&
        data.projectId is string &&
        data.userId is string &&
        data.email is string &&
        data.displayName is string &&
        data.role is string &&
        (
          data.role == 'MEMBER' ||
          (
            data.role == 'OWNER' &&
            isProjectOwner(data.projectId)
          )
        );
    }

    function canReadTask(data) {
      return isAuthenticated() && data != null && (
        (
          data.keys().hasAny(['projectId']) &&
          data.projectId is string &&
          isProjectMember(data.projectId)
        ) ||
        isTaskActorFromData(data)
      );
    }

    function validThreadParticipants(projectId, participantIds) {
      let project = projectData(projectId);
      let allowedParticipantIds = (
        (
          project.memberIds is list
            ? project.memberIds
            : []
        ).concat(
          (
            project.members is list
              ? project.members
              : []
          )
        ).concat(
          project.keys().hasAny(['ownerId']) && project.ownerId is string
            ? [project.ownerId]
            : []
        )
      );
      return participantIds is list &&
        participantIds.size() > 0 &&
        participantIds.size() <= 50 &&
        authUid() in participantIds &&
        projectExists(projectId) &&
        allowedParticipantIds.size() > 0 &&
        participantIds.hasOnly(allowedParticipantIds);
    }

    function inThread(threadId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/chat_threads/$(threadId)) &&
        get(/databases/$(database)/documents/chat_threads/$(threadId)).data.participantIds is list &&
        authUid() in get(/databases/$(database)/documents/chat_threads/$(threadId)).data.participantIds;
    }

    function isReadReceiptOnlyUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['readBy']) &&
        resource.data.readBy is list &&
        request.resource.data.readBy is list &&
        listChangesOnlySelf(resource.data.readBy, request.resource.data.readBy);
    }

    match /users/{userId} {
      allow read: if isSelf(userId);
      allow create: if isSelf(userId) &&
        request.resource.data.keys().hasOnly([
          'userId',
          'email',
          'displayName',
          'photoUrl',
          'fcmToken',
          'deviceInfo',
          'tokenLastUpdated'
        ]) &&
        (!request.resource.data.keys().hasAny(['userId']) || request.resource.data.userId == userId) &&
        (!request.resource.data.keys().hasAny(['email']) || request.resource.data.email == authEmail());
      allow update: if isSelf(userId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'userId',
          'email',
          'displayName',
          'photoUrl',
          'fcmToken',
          'deviceInfo',
          'tokenLastUpdated'
        ]) &&
        (!request.resource.data.keys().hasAny(['userId']) || request.resource.data.userId == userId) &&
        (!request.resource.data.keys().hasAny(['email']) || request.resource.data.email == authEmail());
      allow delete: if isSelf(userId);
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        hasValidProjectWriteShape(request.resource.data, authUid());

      allow update: if (
        isProjectOwner(projectId) &&
        hasValidProjectWriteShape(request.resource.data, resource.data.ownerId)
      ) || (
        !isProjectOwner(projectId) &&
        isSelfMembershipOnlyProjectUpdate()
      );
      allow delete: if isProjectOwner(projectId);

      match /members/{memberId} {
        allow read: if isProjectMember(projectId);

        allow create, update: if (
          isProjectOwner(projectId) &&
          isValidProjectMemberWrite(request.resource.data, projectId, memberId, true)
        ) || (
          isSelf(memberId) &&
          isValidProjectMemberWrite(request.resource.data, projectId, memberId, false)
        );

        allow delete: if isProjectOwner(projectId) || isSelf(memberId);
      }
    }

    match /project_members/{memberDocId} {
      allow read: if resource.data != null &&
        resource.data.projectId is string &&
        isProjectMember(resource.data.projectId);

      allow create, update: if request.resource.data != null &&
        isValidLegacyMemberWrite(request.resource.data);

      allow delete: if canManageLegacyMemberDoc(resource.data);
    }

    match /projectMembers/{memberDocId} {
      allow read: if resource.data != null &&
        resource.data.projectId is string &&
        isProjectMember(resource.data.projectId);

      allow create, update: if request.resource.data != null &&
        isValidLegacyMemberWrite(request.resource.data);

      allow delete: if canManageLegacyMemberDoc(resource.data);
    }

    match /project_invitations/{invitationId} {
      allow read: if resource.data != null && canReadInvitation(resource.data);

      allow create: if isAuthenticated() &&
        request.resource.data.projectId is string &&
        request.resource.data.inviterId == authUid() &&
        request.resource.data.status == 'PENDING' &&
        request.resource.data.inviteeEmail is string &&
        request.resource.data.inviteeEmail == request.resource.data.inviteeEmail.lower() &&
        isProjectOwner(request.resource.data.projectId);

      allow update: if isInvitationActorFromData(resource.data) && (
        (
          isInvitationRecipientFromData(resource.data) &&
          resource.data.status == 'PENDING' &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['inviteeId', 'status']) &&
          request.resource.data.inviteeId == authUid() &&
          request.resource.data.status in ['ACCEPTED', 'REJECTED']
        )
      );

      allow delete: if isInvitationActorFromData(resource.data) || isProjectOwner(resource.data.projectId);
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.createdBy == authUid() &&
        request.resource.data.userId == authUid() &&
        request.resource.data.visibleToUserIds is list &&
        authUid() in request.resource.data.visibleToUserIds &&
        (
          request.resource.data.projectId == null ||
          (
            request.resource.data.projectId is string &&
            isProjectMember(request.resource.data.projectId)
          )
        );

      allow update, delete: if (
        resource.data.projectId != null && isProjectMember(resource.data.projectId)
      ) || isTaskActorFromData(resource.data);
    }

    match /chat_threads/{threadId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
        request.resource.data.projectId is string &&
        isProjectMember(request.resource.data.projectId) &&
        validThreadParticipants(request.resource.data.projectId, request.resource.data.participantIds);

      allow update: if isAuthenticated() &&
        resource.data.participantIds is list &&
        authUid() in resource.data.participantIds && (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastMessagePreview', 'lastUpdatedAt']) ||
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'id',
              'projectId',
              'taskId',
              'participantIds',
              'createdAt',
              'lastMessagePreview',
              'lastUpdatedAt'
            ]) &&
            request.resource.data.id == resource.data.id &&
            request.resource.data.projectId == resource.data.projectId &&
            request.resource.data.taskId == resource.data.taskId &&
            request.resource.data.createdAt == resource.data.createdAt &&
            request.resource.data.participantIds == resource.data.participantIds
          )
        );

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAuthenticated();

        allow create: if isAuthenticated() &&
          inThread(threadId) &&
          request.resource.data.threadId == threadId &&
          request.resource.data.senderId == authUid() &&
          request.resource.data.keys().hasAll(['threadId', 'senderId', 'text', 'type', 'timestamp']);

        allow update: if inThread(threadId) && isReadReceiptOnlyUpdate();
        allow delete: if false;
      }
    }
  }
}
