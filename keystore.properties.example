# Copy to keystore.properties (gitignored). Use the keystore Google Play expects for uploads.
#
# Legacy JKS example:
#   storeFile=release-key.keystore
#   keyAlias=release
#
# Typical PKCS #12 after "upload key reset" (alias often "upload"):
#   storeFile=/Users/you/Downloads/TaskManagerUploadKey/play-upload.p12
#   keyAlias=upload

storeFile=release-key.keystore
storePassword=change-me
keyAlias=release
keyPassword=change-me
